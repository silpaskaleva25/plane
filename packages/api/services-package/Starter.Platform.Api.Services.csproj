<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- NuGet Package Configuration -->
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageId>Starter.Platform.Api.Services</PackageId>
    <PackageVersion>1.0.0</PackageVersion>
    <PackageDescription>API Services utility library for the Starter Platform containing helper
      methods and common functionality.</PackageDescription>
    <PackageAuthors>Starter Platform Team</PackageAuthors>
    <PackageCompany>Organization</PackageCompany>
    <PackageProjectUrl>https://github.com/example-org/starter-platform</PackageProjectUrl>
    <RepositoryUrl>https://github.com/example-org/starter-platform</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>utilities;api;services;starter;starter;platform;helpers</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Copyright>Copyright © Organization 2025</Copyright>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="8.0.0" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="8.0.0" />
    <PackageReference Include="Asp.Versioning.Http" Version="8.1.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="**/*.cs" Pack="true" PackagePath="src\" />
  </ItemGroup>

</Project>
